DGENTIC_APP_NAME=DGentic
DGENTIC_ENVIRONMENT=development
DGENTIC_ROOT_DIR=.
DGENTIC_DATA_DIR=.dgentic
# Leave unset to use SQLite at DGENTIC_DATA_DIR/dgentic.db.
# DGENTIC_DATABASE_URL=sqlite:///.dgentic/dgentic.db
DGENTIC_AUTOPILOT_ENABLED=false
# Auth is off by default in development and on by default in staging/production.
# When auth is enabled, at least one token=capabilities entry is required.
# DGENTIC_AUTH_ENABLED=true
# DGENTIC_AUTH_TOKENS=admin-token=admin;task-token=tasks
DGENTIC_OLLAMA_BASE_URL=http://127.0.0.1:11434
DGENTIC_LM_STUDIO_BASE_URL=http://127.0.0.1:1234
# Extra exact provider base URLs that are trusted for provider calls.
DGENTIC_PROVIDER_ALLOWED_BASE_URLS=
# Optional outbound domain policy JSON. Empty defaults to allow.
# Modes: allow, deny, approval_required, audit.
# Example: {"default_mode":"deny","rules":[{"domain":"api.example.com","mode":"allow"}]}
DGENTIC_NETWORK_DOMAIN_POLICY=
# OpenAI-compatible external adapter is disabled until base URL, models, and either
# an API key environment variable or a persisted credential reference are configured.
# The base URL must use HTTPS. Credential references store only external locations,
# never raw secret values.
DGENTIC_EXTERNAL_OPENAI_COMPATIBLE_BASE_URL=
DGENTIC_EXTERNAL_OPENAI_COMPATIBLE_API_KEY_ENV=
DGENTIC_EXTERNAL_OPENAI_COMPATIBLE_CREDENTIAL_REF=
DGENTIC_EXTERNAL_OPENAI_COMPATIBLE_MODELS=
# Optional Fernet key for local encrypted credential-vault references.
# Generate and store outside DGentic state: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DGENTIC_CREDENTIAL_VAULT_KEY=
# Optional shell-free credential process adapters for mounted secret-manager CLIs.
# Command argv[0] must be an absolute executable path. DGentic appends secret_name.
# Example: {"process-vault":{"argv":["C:\\tools\\secret-fetch.exe","--name"]}}
DGENTIC_CREDENTIAL_PROCESS_ADAPTERS=
DGENTIC_CREDENTIAL_PROCESS_TIMEOUT_SECONDS=5
DGENTIC_CREDENTIAL_PROCESS_MAX_OUTPUT_BYTES=4096
