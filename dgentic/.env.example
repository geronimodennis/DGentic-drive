# DGentic Environment Configuration
# Copy this to .env and fill in your values

# Environment
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=DGentic API
API_VERSION=0.1.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dgentic
REDIS_URL=redis://localhost:6379

# External APIs
OPENAI_API_KEY=your_openai_key_here
GOOGLE_AI_API_KEY=your_google_ai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# Security
PERMISSION_MODE=approval_required
JWT_SECRET_KEY=your_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Storage & Paths
ROOT_DIRECTORY=~/dgentic_workspace
LOCALMCP_DIRECTORY=localmcp
MEMORY_DIRECTORY=memory
LOGS_DIRECTORY=logs

# Memory & Vector DB
VECTOR_DB_TYPE=faiss
VECTOR_DB_DIMENSION=1536
VECTOR_DB_PATH=faiss_index

# Agent Configuration
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT_SECONDS=300

# Tool Runtime
TOOL_TIMEOUT_SECONDS=60
TOOL_MAX_MEMORY_MB=512
ENABLE_DOCKER_SANDBOX=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_WEB_SEARCH=true
ENABLE_CODE_EXECUTION=true
ENABLE_FILE_OPERATIONS=true
